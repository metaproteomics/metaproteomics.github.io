---
/**
 * ManuscriptAnnouncement
 * Full-width banner announcing the current round of the MPI Best Manuscript Award.
 * Contains hardcoded content — update the text here when a new award cycle begins.
 */
---

<div class="w-full bg-blue-50">
  <div class="max-w-screen-xl mx-auto px-5 py-5 flex flex-col sm:flex-row sm:items-center gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-semibold uppercase tracking-widest text-blue-500">Voting open</span>
      </div>
      <h2 class="text-lg font-bold text-slate-900">
        MPI Best Manuscript Award &mdash; Vote for your favorite!
      </h2>
      <p class="text-sm text-slate-600 mt-1">
        The three finalists have been selected. Cast your vote as a Metaproteomics Initiative member before May 6, 2026, 12:00 noon (CET).
      </p>
    </div>
    <div class="flex flex-col sm:items-end gap-2 shrink-0">
      <span class="text-xs font-semibold text-slate-500">
        Voting deadline: <span class="text-slate-800">May 6, 2026, 12:00 noon (CET)</span>
      </span>
      <a
        href="/best-manuscript-vote"
        class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors whitespace-nowrap">
        Vote now &rarr;
      </a>
    </div>
  </div>
</div>
