---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import labsData from "../data/labs.json";

const countries = labsData.countries || [];
const totalLabs = countries.reduce((sum, c) => sum + (c.labs?.length || 0), 0);
const totalCountries = countries.length;
---

<Layout title="groups">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Research Groups</Fragment>
      <Fragment slot="desc">
        The members of the Metaproteomics Initiative.
      </Fragment>
    </Sectionhead>

    <div class="grid lg:grid-cols-2 items-start gap-8 lg:gap-16 mt-16">
      <div>
        <p class="text-lg leading-relaxed text-slate-600">
          The Metaproteomics Initiative brings together research groups from around the world
          who are dedicated to advancing the field of metaproteomics. Our members include
          laboratories specializing in wet-lab methods, mass spectrometry, and bioinformatics,
          united by a shared goal of understanding microbial communities through their protein
          content.
        </p>
        <div class="mt-6 flex flex-wrap gap-x-8 gap-y-2 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <span class="font-semibold text-slate-800">{totalLabs}</span> member laboratories
          </div>
          <div class="flex items-center gap-2">
            <span class="font-semibold text-slate-800">{totalCountries}</span> countries represented
          </div>
        </div>
      </div>

      <div class="border border-slate-200 rounded-xl p-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-3">Join the Initiative</h2>
        <p class="text-slate-500 mb-6">
          Want your lab on this list? Become a member and add your lab to the
          Metaproteomics Initiative.
        </p>
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSdZUBIRB1QzDkcyzA1H1PWCUmucne3JVWcBwPucNzUGDTDFXQ/viewform"
          class="inline-flex items-center gap-2 bg-black text-white px-5 py-2.5 rounded hover:bg-gray-800 transition-colors">
          Add your lab
        </a>
      </div>
    </div>

    <div class="mt-12">
      {countries.map((c) => (
        <div class="mt-12">
          <div class="flex items-center gap-4 mb-6">
            <span class="text-blue-400 uppercase tracking-wider text-sm font-semibold">
              {c.country}
            </span>
            <div class="flex-1 border-t border-slate-200"></div>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {c.labs && c.labs.map((lab) => {
              const hasWebsite = !!(lab.website && lab.website.trim());
              const place = [lab.institute, lab.city].filter(Boolean).join(", ");
              return (
                <div class="border border-slate-200 rounded-xl p-5 flex flex-col gap-1">
                  {hasWebsite ? (
                    <a class="font-semibold text-gray-900 hover:underline" href={lab.website}>
                      {lab.name}
                    </a>
                  ) : (
                    <span class="font-semibold text-gray-900">{lab.name}</span>
                  )}
                  {place && (
                    <p class="text-sm text-slate-500">{place}</p>
                  )}
                  {lab.groupLeader && (
                    <p class="text-sm text-slate-400">{lab.groupLeader}</p>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </Container>
</Layout>
