---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

const publishedBlogEntries = await getCollection("news", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

publishedBlogEntries.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const byYear = publishedBlogEntries.reduce((acc, entry) => {
  const year = entry.data.publishDate.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(entry);
  return acc;
}, {} as Record<number, typeof publishedBlogEntries>);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<Layout title="News">
  <Container>
    <Sectionhead>
      <Fragment slot="title">News</Fragment>
      <Fragment slot="desc">The latest metaproteomics news.</Fragment>
    </Sectionhead>

    <div class="mt-16">
      {years.map((year) => (
        <div class="mt-12 first:mt-0">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-blue-400 uppercase tracking-wider text-sm font-semibold shrink-0">{year}</span>
            <div class="flex-1 border-t border-slate-200"></div>
          </div>
          <ul>
            {byYear[year].map((entry) => (
              <li>
                <a
                  href={`/news/${entry.id}`}
                  class="flex items-start justify-between gap-6 py-3 border-b border-slate-100 hover:opacity-70 transition-opacity group">
                  <div>
                    <span class="font-semibold text-gray-900">{entry.data.title}</span>
                    {entry.data.description && (
                      <p class="text-sm text-slate-500 mt-0.5">{entry.data.description}</p>
                    )}
                  </div>
                  <span class="text-sm text-slate-400 shrink-0 mt-0.5">
                    {entry.data.publishDate.toLocaleDateString("en-GB", { day: "numeric", month: "short" })}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </Container>
</Layout>
