---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

// Filter blog entries with 'draft: false' & date before current date
let symposia = await getCollection("symposia", ({ data }) => {
  return !data.draft;
});

// Sort content entries by publication date
symposia.sort(function (a, b) {
  if (a.data.sortDate === b.data.sortDate) {
    return 0;
  }
  if (a.data.sortDate < b.data.sortDate) {
    return 1;
  }
  return -1;
});
---

<Layout title="Symposia">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Symposia</Fragment>
      <Fragment slot="desc">
        The International Metaproteomics Symposia.
      </Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-3 mt-16">
      <h2 class="font-medium text-2xl text-gray-800">
        About the International Metaproteomics Symposia
      </h2>
      <p class="text-lg leading-relaxed text-slate-500">
        Every 18 months, the International Metaproteomics Symposium brings
        together researchers from around the world to discuss the latest
        developments in metaproteomics.
      </p>
    </div>
    <main class="mt-16">
      <ul class="grid gap-10">
        {
          symposia.map((symposium, index) => (
            <li>
              <a href={`/symposia/${symposium.slug}`} class="grid md:grid-cols-[1fr_2fr] gap-6 md:gap-10 items-start hover:opacity-80 transition-opacity">
                {symposium.data.photo && (
                  <img
                    src={symposium.data.photo}
                    alt={symposium.data.caption ?? ''}
                    class="w-full rounded-lg object-cover aspect-video"
                    loading={index <= 2 ? "eager" : "lazy"}
                    decoding={index <= 2 ? "sync" : "async"}
                  />
                )}
                <div>
                  <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
                    {symposium.data.location}
                  </span>
                  <h2 class="text-2xl font-semibold leading-snug tracking-tight mt-1">
                    {symposium.data.title}
                  </h2>
                  <span class="text-sm text-gray-400 mt-2 block">{symposium.data.date}</span>
                  {symposium.data.description && (
                    <p class="text-slate-500 leading-relaxed mt-3">{symposium.data.description}</p>
                  )}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </Container>
</Layout>
