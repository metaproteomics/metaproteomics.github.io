---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const symposia = await getCollection("symposia");
  return symposia.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the entry directly from the prop on render
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <Container>
    <div class="mt-16">
      <div class="flex items-center gap-2 text-sm">
        <span class="text-blue-400 uppercase tracking-wider font-semibold">{entry.data.location}</span>
        <span class="text-slate-300">·</span>
        <time class="text-slate-500">{entry.data.date}</time>
      </div>
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-3 lg:leading-tight">
        {entry.data.title}
      </h1>
      {entry.data.description && (
        <p class="text-lg mt-4 text-slate-600">{entry.data.description}</p>
      )}
    </div>
    <hr class="border-slate-200 mt-10" />

    <div class={`mt-10 ${entry.data.website ? "flex items-start gap-10" : ""}`}>
      <div class={`prose prose-lg symposia-content ${entry.data.website ? "flex-1" : "max-w-2xl mx-auto"}`}>
        <Content />
      </div>
      {entry.data.website && (
        <div class="shrink-0 border border-slate-200 rounded-xl p-8 max-w-sm">
          <h2 class="text-xl font-semibold text-gray-800 mb-3">Register &amp; Learn More</h2>
          <p class="text-slate-500 mb-6">
            Visit the official symposium website to register, view the programme, and find practical information.
          </p>
          <a
            href={entry.data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-black text-white px-5 py-2.5 rounded hover:bg-gray-800 transition-colors">
            Symposium website
          </a>
        </div>
      )}
    </div>

    <div class="mt-12 pt-8 border-t border-slate-200">
      <a href="/symposia" class="text-sm text-slate-500 hover:text-slate-800 transition-colors">
        ← Back to all symposia
      </a>
    </div>
  </Container>
</Layout>

<style>
  .symposia-content :global(h1) {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.5;
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    color: #1e293b;
  }

  .symposia-content :global(h2) {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.5;
    margin-top: 1.75rem;
    margin-bottom: 0.375rem;
    color: #334155;
  }

  .symposia-content :global(h3) {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.5;
    margin-top: 1.25rem;
    margin-bottom: 0.25rem;
    color: #475569;
  }

  .symposia-content :global(figure.image-card) {
    margin: 1.75rem 0;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #ffffff;
  }

  .symposia-content :global(figure.image-card img) {
    width: 100%;
    max-width: none;
    margin: 0;
    border-radius: 0;
    display: block;
  }

  .symposia-content :global(figure.image-card figcaption) {
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    color: #64748b;
    line-height: 1.5;
    font-style: normal;
    border-top: 1px solid #e2e8f0;
  }
</style>
